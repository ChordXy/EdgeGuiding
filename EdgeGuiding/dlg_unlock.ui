/* 按下状态（核心：按压效果） */
QPushButton:pressed {
	background-color: #2E7D32; /* 更深的绿色 */
	border: 2px solid #1B5E20; /* 更暗的边框 */
	padding-left: 2px;         /* 文字右移2px */
	padding-top: 2px;          /* 文字下移2px */
}</string>
