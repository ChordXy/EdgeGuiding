    <property name="styleSheet">
     <string notr="true">        QPushButton {\n            background-color: #4CAF50; /* 绿色背景 */\n            color: white;              /* 白色文字 */\n            border: 2px solid #388E3C; /* 深绿边框 */\n            border-radius: 8px;        /* 圆角 */\n            font-size: 14px;\n        }\n        /* 悬浮状态（鼠标移上去） */\n        QPushButton:hover {\n            background-color: #66BB6A; /* 浅绿背景 */\n        }\n        /* 按下状态（核心：按压效果） */\n        QPushButton:pressed {\n            background-color: #2E7D32; /* 更深的绿色 */\n            border: 2px solid #1B5E20; /* 更暗的边框 */\n            padding-left: 2px;         /* 文字右移2px */\n            padding-top: 2px;          /* 文字下移2px */\n        }</string>
    </property>
    <property name="text">
     <string>标定</string>
    </property>
